# Required — get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...

# Optional — enables fortress site scraping (linkedin, instagram, etc.)
APIFY_TOKEN=apify_api_...

# Password for the web interface (default: pluck)
PLUCK_PASSWORD=your_password_here

# Intent-aware Apify planner + discovery fall-through. Defaults to true.
# set to false to disable the intent-aware planner and discovery fall-through
USE_PLANNER=true

# Logging verbosity. Valid values: DEBUG, INFO, WARNING, ERROR, CRITICAL (default: INFO)
LOG_LEVEL=INFO
