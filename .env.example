# Required — get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...

# Optional — enables fortress site scraping (linkedin, instagram, etc.)
APIFY_TOKEN=apify_api_...

# Password for the web interface (default: pluck)
PLUCK_PASSWORD=your_password_here

# Optional — route registry hosts through the intent-aware Apify planner
USE_PLANNER=false
